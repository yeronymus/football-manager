# 🛠️ LOCAL DEVELOPMENT CONFIGURATION (DEEP LINKS / POLLING / SQLLITE OR LOCAL POSTGRES)
# RENAME TO .env.dev ON YOUR LOCAL COMPUTER AND SET AS ACTIVE .env

# ==============================================================================
# 🤖 Telegram Bot Configuration
# ==============================================================================
# Get a separate bot token from @BotFather for local testing (e.g. fm_dev_bot)
BOT_TOKEN=YOUR_DEV_BOT_TOKEN
BOT_USERNAME=YOUR_DEV_BOT_USERNAME

# JSON list of static admin IDs (your personal Telegram user ID)
ADMIN_IDS='[123456789]'
SYSTEM_OWNER_ID=123456789

# Authorized chats for local testing (can use your personal chat or a test group ID)
INITIAL_CHATS='[{"id": -1001234567890, "title": "FM Dev Chat", "admin_chat_id": -1009876543210}]'

# ==============================================================================
# ⚙️ Application Settings
# ==============================================================================
DEBUG=True
# In local development, Polling is highly recommended so you don't need a public HTTPS domain/webhook!
USE_POLLING=True
WEBHOOK_URL=

# ==============================================================================
# 💾 Databases
# ==============================================================================
# Database URL (using PostgreSQL on localhost, or SQLite if running in memory)
# For local PostgreSQL container (accessed from host):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
# For SQLite (Uncomment to use lightweight SQLite for testing instead of Postgres):
# DATABASE_URL=sqlite+aiosqlite:///./dev_database.db

# Redis connection string (accessed from host)
REDIS_URL=redis://localhost:6379/0

# ==============================================================================
# 🌐 WebApp (Telegram Mini App)
# ==============================================================================
# Local address of your frontend web application (e.g., Vite/React dev server)
WEBAPP_URL=http://localhost:5173

# ==============================================================================
# 🔌 Port Mappings (Host:Container)
# ==============================================================================
APP_PORT=8000
DB_PORT=5432
REDIS_PORT=6379
